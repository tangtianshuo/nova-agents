{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "NovaAgents",
	"version": "0.2.0",
	"identifier": "com.novaagents.app",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "npm run dev:web",
		"beforeBuildCommand": "npm run build:web"
	},
	"app": {
		"windows": [
			{
				"title": "NovaAgents",
				"label": "main",
				"width": 1200,
				"height": 800,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"center": true,
				"decorations": true,
				"transparent": true,
				"hiddenTitle": true,
				"titleBarStyle": "Overlay",
				"trafficLightPosition": {
					"x": 14,
					"y": 20
				}
			}
		],
		"security": {
			"csp": "default-src \u0027self\u0027 ipc: tauri: asset: http://ipc.localhost; script-src \u0027self\u0027 \u0027unsafe-inline\u0027; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; font-src \u0027self\u0027 data:; connect-src \u0027self\u0027 ipc: tauri: asset: http://ipc.localhost http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* https://download.nova-agents.io; fetch-src \u0027self\u0027 ipc: tauri: asset: http://ipc.localhost https://download.nova-agents.io; img-src \u0027self\u0027 data: blob: asset: https://asset.localhost https://download.nova-agents.io https:; media-src \u0027self\u0027 blob: asset: http://asset.localhost https://asset.localhost;",
			"dangerousDisableAssetCspModification": true
		}
	},
	"bundle": {
		"active": true,
		"targets": ["dmg", "app", "nsis"],
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": {
			"../src-tauri/resources/server-dist.js": "server-dist.js",
			"../src-tauri/resources/plugin-bridge-dist.js": "plugin-bridge-dist.js",
			"../src/server/plugin-bridge/sdk-shim": "plugin-bridge-sdk-shim",
			"../src-tauri/resources/claude-agent-sdk": "claude-agent-sdk",
			"../src-tauri/resources/agent-browser-cli": "agent-browser-cli",
			"../src-tauri/resources/nodejs": "nodejs",
			"../src/shared": "shared",
			"../bundled-skills": "bundled-skills",
			"../bundled-agents": "bundled-agents",
			"../NOVA": "NOVA",
			"../src/cli": "cli",
			"infoplist/en.lproj/InfoPlist.strings": "en.lproj/InfoPlist.strings",
			"infoplist/zh-Hans.lproj/InfoPlist.strings": "zh-Hans.lproj/InfoPlist.strings"
		},
		"externalBin": ["binaries/bun"],
		"macOS": {
			"minimumSystemVersion": "13.0",
			"entitlements": "Entitlements.plist",
			"exceptionDomain": "",
			"frameworks": [],
			"providerShortName": null,
			"signingIdentity": null,
			"dmg": {
				"appPosition": {
					"x": 180,
					"y": 170
				},
				"applicationFolderPosition": {
					"x": 480,
					"y": 170
				},
				"windowSize": {
					"width": 660,
					"height": 400
				}
			}
		},
		"windows": {
			"certificateThumbprint": null,
			"timestampUrl": null,
			"allowDowngrades": true,
			"webviewInstallMode": {
				"type": "downloadBootstrapper"
			},
			"nsis": {
				"template": "nsis/installer.nsi",
				"installerIcon": "icons/icon.ico",
				"headerImage": null,
				"sidebarImage": null,
				"installMode": "currentUser",
				"languages": ["SimpChinese", "English"],
				"displayLanguageSelector": false,
				"customLanguageFiles": {
					"SimpChinese": "nsis/languages/SimpChinese.nsh",
					"English": "nsis/languages/English.nsh"
				}
			}
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFM0M2NTQ4Rjg3QzE4NDgKUldSSUdIejRTR1U4anBNaDVSZS9VTks4ZFlOS0xBTVpSSExpWmxoZGZOQUFEN2JwTzFtVGgrY28K",
			"endpoints": ["https://download.novai.net.cn/update/{{target}}.json"]
		}
	}
}
